{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": [
    {
      "source": "apps/api",
      "codebase": "default",
      "runtime": "nodejs20",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        "**/*.ts",
        "tsconfig.json",
        "tsconfig.build.json"
      ],
      "predeploy": ["npm ci", "npx nx run api:build"]
    }
  ],
  "hosting": {
    "public": "apps/web/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/**",
        "function": {
          "functionId": "api",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
