{
  "name": "anti-gravity-training-portal",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "nx": "nx",
    "install:all": "npm install",
    "dev": "nx run-many -t dev -p web,api --parallel=2 --outputStyle=tui",
    "dev:all": "npm run dev",
    "run:all": "npm run dev",
    "build": "nx run web:build",
    "build:all": "nx run-many -t build --projects=web",
    "dev:web": "nx run web:dev",
    "dev:api": "nx run api:dev",
    "lint": "nx run web:lint",
    "typecheck:api": "nx run api:typecheck",
    "graph": "nx graph",
    "deploy:hosting": "npm run build && npx firebase-tools@13 deploy --only hosting --project fit-managment"
  },
  "devDependencies": {
    "nx": "~21.6.0"
  }
}
